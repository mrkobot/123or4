# Documents which environment variables the app needs. No real values here —
# copy to .env.local and fill in real values there (that file is gitignored).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth client ID (not secret — safe to be public, used client-side)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Local-only, used by the Supabase CLI to run migrations
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=
